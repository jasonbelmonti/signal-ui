{
  "name": "@jasonbelmonti/signal-ui",
  "version": "0.7.1",
  "description": "Signal-driven React and Ant Design UI package for desktop apps.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonbelmonti/signal-ui.git"
  },
  "homepage": "https://github.com/jasonbelmonti/signal-ui#readme",
  "bugs": {
    "url": "https://github.com/jasonbelmonti/signal-ui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "bun run clean && bun x tsc -p tsconfig.build.json && bun run scripts/build-css.ts",
    "clean": "rm -rf dist",
    "prepack": "bun run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "bun x tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@ant-design/x": "^2.3.0",
    "@dagrejs/dagre": "^2.0.4",
    "@fontsource/azeret-mono": "5.2.11",
    "@fontsource/doto": "^5.2.10",
    "@fontsource/micro-5": "^5.2.7",
    "@fontsource/oxanium": "5.2.8",
    "@react-three/fiber": "9.5.0",
    "@xyflow/react": "^12.10.1",
    "three": "0.183.2"
  },
  "peerDependencies": {
    "@ant-design/icons": "6.1.0",
    "antd": "6.3.1",
    "react": ">=19 <19.3",
    "react-dom": ">=19 <19.3"
  },
  "devDependencies": {
    "@ant-design/icons": "6.1.0",
    "@changesets/cli": "^2.30.0",
    "@storybook/addon-a11y": "10.2.16",
    "@storybook/addon-docs": "10.2.16",
    "@storybook/addon-webpack5-compiler-swc": "4.0.2",
    "@storybook/react-webpack5": "10.2.16",
    "@types/bun": "^1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.183.1",
    "antd": "6.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "storybook": "10.2.16",
    "typescript": "^5.9.3"
  }
}
